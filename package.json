{
  "name": "@marius-patrik/andromeda",
  "version": "0.10.0",
  "description": "Authoritative Andromeda product surface with `andromeda`, `agent`, and `agents` command aliases.",
  "type": "module",
  "bin": {
    "andromeda": "./src/cli/cli.ts",
    "agent": "./src/cli/cli.ts",
    "agents": "./src/cli/cli.ts",
    "andromeda-memory": "./src/memory/cli.ts"
  },
  "exports": {
    "./sdk": "./src/sdk/shared-ts/index.ts",
    "./sdk/gen": "./src/sdk/shared-ts/gen/index.ts",
    "./sdk/agent-package.schema.json": "./src/sdk/agent-package.schema.json"
  },
  "scripts": {
    "agent": "bun src/cli/cli.ts",
    "agents": "bun src/cli/cli.ts",
    "check": "bun x tsc --noEmit",
    "test": "bun test src/cli/test/*.test.ts",
    "proto:check": "bun scripts/verify-codegen.ts",
    "layout:check": "node scripts/verify-single-product.mjs",
    "ci": "node scripts/run-ci-suite.mjs all",
    "test:compact": "pwsh -NoProfile -ExecutionPolicy Bypass -File .agents/global/skills/compact/scripts/test_write_compaction_capsule.ps1",
    "smoke:release": "bun scripts/run-release-smoke.mjs",
    "smoke:sync": "bun scripts/run-sync-smoke.mjs"
  },
  "dependencies": {
    "@agentclientprotocol/sdk": "0.23.0",
    "@bufbuild/protobuf": "2.12.1",
    "@connectrpc/connect": "2.1.2",
    "@octokit/app": "15.1.2",
    "@octokit/core": "7.0.6",
    "dotenv": "16.4.7",
    "semver": "7.8.5",
    "spdx-expression-parse": "5.0.0",
    "zod": "4.3.6"
  },
  "devDependencies": {
    "@bufbuild/buf": "1.71.0",
    "@types/bun": "1.3.14",
    "@types/semver": "7.7.1",
    "@types/spdx-expression-parse": "4.0.0",
    "ajv": "8.20.0",
    "js-yaml": "4.3.0",
    "tsx": "4.23.0",
    "typescript": "5.9.3"
  },
  "engines": {
    "bun": "1.3.14"
  },
  "license": "Apache-2.0"
}
