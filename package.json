{
  "name": "@marius-patrik/andromeda",
  "version": "0.10.0",
  "description": "Authoritative Agent OS package surface for the unified `agents` CLI and the Andromeda system implementation.",
  "type": "module",
  "bin": {
    "andromeda": "./src/cli/cli.ts",
    "andromeda-memory": "./src/memory/cli.ts"
  },
  "exports": {
    "./sdk": "./src/sdk/shared-ts/index.ts",
    "./sdk/gen": "./src/sdk/shared-ts/gen/index.ts"
  },
  "scripts": {
    "agents": "bun src/cli/cli.ts",
    "check": "bunx tsc --noEmit",
    "test": "bun test src/cli/test/*.test.ts",
    "proto:check": "bun scripts/verify-codegen.ts",
    "layout:check": "node scripts/verify-single-product.mjs",
    "ci": "node scripts/run-ci-suite.mjs all",
    "test:compact": "pwsh -NoProfile -ExecutionPolicy Bypass -File .agents/capabilities/global/skills/compact/scripts/test_write_compaction_capsule.ps1",
    "smoke:release": "bun scripts/run-release-smoke.mjs",
    "smoke:sync": "bun scripts/run-sync-smoke.mjs"
  },
  "dependencies": {
    "@agentclientprotocol/sdk": "0.23.0",
    "@bufbuild/protobuf": "2.12.1",
    "@connectrpc/connect": "2.1.2",
    "@octokit/app": "15.1.2",
    "@octokit/core": "7.0.6",
    "dotenv": "16.4.7",
    "zod": "4.3.6"
  },
  "devDependencies": {
    "@bufbuild/buf": "1.71.0",
    "@types/bun": "1.3.14",
    "js-yaml": "4.3.0",
    "tsx": "4.23.0",
    "typescript": "5.9.3"
  },
  "engines": {
    "bun": "1.3.14"
  },
  "license": "MIT"
}
