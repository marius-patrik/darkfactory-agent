{
  "name": "darkfactory-agent",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "bin": {
    "df": "./dist/cli.js",
    "darkfactory": "./dist/cli.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "check": "npm run typecheck && npm test && npm run build",
    "dev": "tsx watch src/cli.ts serve",
    "install:url": "tsx src/cli.ts install-url",
    "sync:managed": "tsx src/cli.ts sync-managed",
    "test": "node --import tsx --test tests/index.ts",
    "start": "node dist/cli.js serve",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@octokit/app": "^15.1.2",
    "dotenv": "^16.4.7"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}
