{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "skipLibCheck": true,
    "noEmit": true,
    "ignoreDeprecations": "6.0",
    "baseUrl": ".",
    "paths": {
      "@agent-os/shared-ts": ["clients/shared-ts/src/index.ts"],
      "@agent-os/shared-ts/gen": ["clients/shared-ts/src/gen/index.ts"],
      "@agent-os/tui": ["clients/tui/src/index.ts"],
      "@agent-os/web": ["clients/web/src/index.ts"]
    }
  },
  "include": [
    "clients/**/*.ts",
    "tests/**/*.ts"
  ]
}
