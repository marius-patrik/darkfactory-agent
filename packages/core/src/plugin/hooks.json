{
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup|resume",
        "hooks": [
          {
            "type": "command",
            "command": "pwsh -NoProfile -ExecutionPolicy Bypass -File C:\\Users\\patrik\\.codex\\hooks\\session_start_memory.ps1",
            "commandWindows": "pwsh -NoProfile -ExecutionPolicy Bypass -File C:\\Users\\patrik\\.codex\\hooks\\session_start_memory.ps1",
            "timeout": 30,
            "statusMessage": "Loading layered memory operating context"
          }
        ]
      },
      {
        "matcher": "startup|resume",
        "hooks": [
          {
            "type": "command",
            "command": "pwsh -NoProfile -ExecutionPolicy Bypass -File C:\\Users\\patrik\\.codex\\hooks\\session_start_sleep_reminder.ps1",
            "commandWindows": "pwsh -NoProfile -ExecutionPolicy Bypass -File C:\\Users\\patrik\\.codex\\hooks\\session_start_sleep_reminder.ps1",
            "timeout": 30,
            "statusMessage": "Checking Rommie memory freshness"
          }
        ]
      },
      {
        "matcher": "startup|resume",
        "hooks": [
          {
            "type": "command",
            "command": "pwsh -NoProfile -ExecutionPolicy Bypass -File C:\\Users\\patrik\\.codex\\hooks\\session_start_breathe.ps1",
            "commandWindows": "pwsh -NoProfile -ExecutionPolicy Bypass -File C:\\Users\\patrik\\.codex\\hooks\\session_start_breathe.ps1",
            "timeout": 30,
            "statusMessage": "Loading Rommie breathe reflection"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "pwsh -NoProfile -ExecutionPolicy Bypass -File C:\\Users\\patrik\\.codex\\hooks\\stop_memory_handoff.ps1",
            "commandWindows": "pwsh -NoProfile -ExecutionPolicy Bypass -File C:\\Users\\patrik\\.codex\\hooks\\stop_memory_handoff.ps1",
            "timeout": 30,
            "statusMessage": "Updating memory handoff"
          },
          {
            "type": "command",
            "command": "pwsh -NoProfile -ExecutionPolicy Bypass -File C:\\Users\\patrik\\.codex\\hooks\\stop_breathe_reflection.ps1",
            "commandWindows": "pwsh -NoProfile -ExecutionPolicy Bypass -File C:\\Users\\patrik\\.codex\\hooks\\stop_breathe_reflection.ps1",
            "timeout": 30,
            "statusMessage": "Updating breathe reflection"
          }
        ]
      }
    ]
  }
}

