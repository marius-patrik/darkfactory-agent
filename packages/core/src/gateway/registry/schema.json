{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Agent OS Gateway Model Registry",
  "type": "object",
  "required": ["schema_version", "models"],
  "properties": {
    "schema_version": {"const": "gateway-registry-v1"},
    "models": {
      "type": "object",
      "minProperties": 1,
      "additionalProperties": {
        "type": "object",
        "required": ["id", "provider", "model", "api_base", "role", "context_length", "enabled"],
        "properties": {
          "id": {"type": "string", "minLength": 1},
          "name": {"type": "string"},
          "provider": {"const": "local"},
          "model": {"type": "string", "minLength": 1},
          "api_base": {"type": "string", "format": "uri"},
          "role": {"enum": ["general", "coding", "conversation", "judge"]},
          "context_length": {"type": "integer", "minimum": 1},
          "quant": {"type": ["string", "null"]},
          "gpu": {"type": ["string", "null"]},
          "tensor_parallel": {"type": ["integer", "null"], "minimum": 1},
          "enabled": {"type": "boolean"}
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
