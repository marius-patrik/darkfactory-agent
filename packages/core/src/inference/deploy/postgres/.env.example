# Copy to deploy/postgres/.env (gitignored) for docker-compose.
# The password is materialized per-node at ~/.rommie/secrets/pg_password (0600) by bring-up.sh.
#   POSTGRES_PASSWORD=$(cat ~/.rommie/secrets/pg_password)
POSTGRES_PASSWORD=set-me-from-rommie-secrets
# Absolute data dir (no ~ expansion in compose). On the servers: /home/<user>/.rommie/pg/data
ROMMIE_PG_DATA=/home/patrik/.rommie/pg/data
