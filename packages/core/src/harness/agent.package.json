{
  "schemaVersion": 1,
  "id": "agents-harness",
  "name": "Agents Harness",
  "kind": "harness",
  "description": "Runtime harness managed by Agentos.",
  "entry": "go run ./cmd/rommie",
  "workingDirectory": "services/cli",
  "provides": [
    "agent-runtime",
    "cli-adapter-host",
    "capability-executor"
  ],
  "requires": {
    "clis": [
      "codex",
      "claude",
      "kimi",
      "agy"
    ],
    "state": [
      "skills",
      "plugins",
      "hooks",
      "credits"
    ]
  }
}
