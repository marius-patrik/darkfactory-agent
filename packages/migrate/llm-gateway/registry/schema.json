{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "GatewayModelRegistry",
  "type": "object",
  "required": ["schema_version", "models"],
  "properties": {
    "schema_version": {
      "type": "string",
      "enum": ["gateway-registry-v1"]
    },
    "models": {
      "type": "object",
      "additionalProperties": {
        "type": "object",
        "required": ["id", "provider", "role", "context_length"],
        "properties": {
          "id": { "type": "string", "minLength": 1 },
          "name": { "type": "string" },
          "provider": {
            "type": "string",
            "enum": ["local", "vllm", "llama.cpp", "litellm-remote", "nvcf"]
          },
          "model": { "type": "string" },
          "api_base": { "type": "string", "format": "uri" },
          "api_key": { "type": "string" },
          "api_key_env": { "type": "string" },
          "role": {
            "type": "string",
            "enum": ["general", "coding", "conversation", "judge", "embedding"]
          },
          "context_length": { "type": "integer", "minimum": 1 },
          "quant": { "type": ["string", "null"] },
          "gpu": { "type": ["string", "null"] },
          "tensor_parallel": { "type": ["integer", "null"], "minimum": 1 },
          "fallback_model": { "type": ["string", "null"] },
          "enabled": { "type": "boolean" },
          "cloud": { "type": "boolean" },
          "extra": { "type": "object" }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
