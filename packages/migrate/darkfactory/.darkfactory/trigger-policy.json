{
  "schemaVersion": 1,
  "policyVersion": "1.2.0",
  "trustedSourceRef": "refs/heads/main",
  "loops": [
    {
      "id": "repository-doctor",
      "ownerIssue": 12,
      "status": "active",
      "engine": "df doctor",
      "eventWorkflows": [".github/workflows/df-audit.yml"],
      "recoveryWorkflow": ".github/workflows/df-audit.yml",
      "eventTriggers": [{ "event": "workflow_dispatch", "types": [] }],
      "recovery": { "cron": "41 5 * * *", "intervalMinutes": 1440, "maxDetectionMinutes": 1500 },
      "settleSeconds": 30,
      "debounceSeconds": 60,
      "idempotencyKey": "repository-doctor:{repository}:{target}:{sourceVersion}",
      "modelPolicy": "zero-token",
      "authorization": {
        "defaultMode": "read-only",
        "mutationAuthority": "scheduled-report-or-explicit-write-issues",
        "permissions": ["administration:read", "actions:read", "checks:read", "contents:read", "issues:write"],
        "receiptRequired": true
      },
      "retry": { "maxAttempts": 3, "backoffSeconds": 300, "noProgressLimit": 3, "escalationLabel": "df:ask-owner" },
      "ledgerKind": "repo-doctor"
    },
    {
      "id": "managed-baseline-sync",
      "ownerIssue": 12,
      "status": "active",
      "engine": "df baseline sync",
      "eventWorkflows": [".github/workflows/sync-managed-repos.yml"],
      "recoveryWorkflow": ".github/workflows/sync-managed-repos.yml",
      "eventTriggers": [{ "event": "workflow_dispatch", "types": [] }],
      "recovery": { "cron": "23 3 * * *", "intervalMinutes": 1440, "maxDetectionMinutes": 1500 },
      "settleSeconds": 60,
      "debounceSeconds": 120,
      "idempotencyKey": "managed-baseline-sync:{repository}:{target}:{sourceVersion}",
      "modelPolicy": "zero-token",
      "authorization": {
        "defaultMode": "read-only",
        "mutationAuthority": "trusted-main-managed-baseline",
        "permissions": ["contents:write", "pull-requests:write", "workflows:write"],
        "receiptRequired": true
      },
      "retry": { "maxAttempts": 3, "backoffSeconds": 600, "noProgressLimit": 3, "escalationLabel": "df:ask-owner" },
      "ledgerKind": "baseline-sync"
    },
    {
      "id": "pr-autoreview-fix",
      "ownerIssue": 36,
      "status": "active",
      "engine": "df pr review|fix",
      "eventWorkflows": [".github/workflows/darkfactory-autoreview.yml", ".github/workflows/df-autoreview-recovery.yml"],
      "recoveryWorkflow": ".github/workflows/df-autoreview-recovery.yml",
      "eventTriggers": [{ "event": "pull_request_target", "types": ["opened", "synchronize", "reopened", "ready_for_review"] }, { "event": "schedule", "types": [] }],
      "recovery": { "cron": "7,22,37,52 * * * *", "intervalMinutes": 15, "maxDetectionMinutes": 25 },
      "settleSeconds": 30,
      "debounceSeconds": 60,
      "idempotencyKey": "pr-autoreview-fix:{repository}:{target}:{sourceVersion}",
      "modelPolicy": "autoreview-medium-clean-high-confirmation",
      "authorization": {
        "defaultMode": "read-only",
        "mutationAuthority": "verified-same-repository-head",
        "permissions": ["checks:write", "contents:write", "issues:write", "pull-requests:write"],
        "receiptRequired": true
      },
      "retry": { "maxAttempts": 4, "backoffSeconds": 120, "noProgressLimit": 3, "escalationLabel": "df:ask-owner" },
      "ledgerKind": "autoreview-pr"
    },
    {
      "id": "issue-autoreview-fix",
      "ownerIssue": 36,
      "status": "active",
      "engine": "df issue review|fix",
      "eventWorkflows": [".github/workflows/darkfactory-autoreview.yml", ".github/workflows/df-autoreview-recovery.yml"],
      "recoveryWorkflow": ".github/workflows/df-autoreview-recovery.yml",
      "eventTriggers": [{ "event": "workflow_dispatch", "types": [] }, { "event": "schedule", "types": [] }],
      "recovery": { "cron": "12,27,42,57 * * * *", "intervalMinutes": 15, "maxDetectionMinutes": 25 },
      "settleSeconds": 30,
      "debounceSeconds": 90,
      "idempotencyKey": "issue-autoreview-fix:{repository}:{target}:{sourceVersion}",
      "modelPolicy": "autoreview-medium-clean-high-confirmation",
      "authorization": {
        "defaultMode": "read-only",
        "mutationAuthority": "exact-owner-history-and-version-cas",
        "permissions": ["issues:write"],
        "receiptRequired": true
      },
      "retry": { "maxAttempts": 4, "backoffSeconds": 120, "noProgressLimit": 3, "escalationLabel": "df:ask-owner" },
      "ledgerKind": "autoreview-issue"
    },
    {
      "id": "interactive-issue-drafting",
      "ownerIssue": 39,
      "status": "planned",
      "engine": "df issue draft",
      "eventWorkflows": [],
      "recoveryWorkflow": null,
      "eventTriggers": [],
      "recovery": null,
      "settleSeconds": 0,
      "debounceSeconds": 120,
      "idempotencyKey": "interactive-issue-drafting:{repository}:{target}:{sourceVersion}",
      "modelPolicy": "high",
      "authorization": {
        "defaultMode": "draft-only",
        "mutationAuthority": "explicit-owner-publish-approval",
        "permissions": ["issues:write"],
        "receiptRequired": true
      },
      "retry": { "maxAttempts": 3, "backoffSeconds": 300, "noProgressLimit": 3, "escalationLabel": "df:ask-owner" },
      "ledgerKind": "issue-draft"
    },
    {
      "id": "issue-draft-hygiene",
      "ownerIssue": 48,
      "status": "active",
      "engine": "deterministic local draft inventory",
      "eventWorkflows": [".github/workflows/df-issue-draft-hygiene.yml"],
      "recoveryWorkflow": ".github/workflows/df-issue-draft-hygiene.yml",
      "eventTriggers": [{ "event": "workflow_dispatch", "types": [] }, { "event": "schedule", "types": [] }],
      "recovery": { "cron": "19 */6 * * *", "intervalMinutes": 360, "maxDetectionMinutes": 390 },
      "settleSeconds": 0,
      "debounceSeconds": 60,
      "idempotencyKey": "issue-draft-hygiene:{repository}:{target}:{sourceVersion}",
      "modelPolicy": "zero-token",
      "authorization": {
        "defaultMode": "local-observation",
        "mutationAuthority": "immutable-local-lifecycle-receipts-only",
        "permissions": ["contents:read"],
        "receiptRequired": true
      },
      "retry": { "maxAttempts": 3, "backoffSeconds": 300, "noProgressLimit": 3, "escalationLabel": "df:ask-owner" },
      "ledgerKind": "issue-draft-hygiene"
    },
    {
      "id": "prd-backlog-reconcile",
      "ownerIssue": 48,
      "status": "active",
      "engine": "df plan",
      "eventWorkflows": [".github/workflows/df-plan.yml"],
      "recoveryWorkflow": ".github/workflows/df-plan.yml",
      "eventTriggers": [{ "event": "push", "types": ["PRD.md", "packages/**/PRD.md"] }, { "event": "workflow_dispatch", "types": [] }],
      "recovery": { "cron": "17 */6 * * *", "intervalMinutes": 360, "maxDetectionMinutes": 390 },
      "settleSeconds": 30,
      "debounceSeconds": 90,
      "idempotencyKey": "prd-backlog-reconcile:{repository}:{target}:{sourceVersion}",
      "modelPolicy": "zero-token",
      "authorization": {
        "defaultMode": "read-only",
        "mutationAuthority": "trusted-prd-source-version",
        "permissions": ["contents:read", "issues:write"],
        "receiptRequired": true
      },
      "retry": { "maxAttempts": 3, "backoffSeconds": 300, "noProgressLimit": 3, "escalationLabel": "df:ask-owner" },
      "ledgerKind": "df-plan"
    },
    {
      "id": "worker-dispatch",
      "ownerIssue": 48,
      "status": "active",
      "engine": "df work",
      "eventWorkflows": [".github/workflows/df-event-forward.yml", ".github/workflows/df-orchestrate.yml"],
      "recoveryWorkflow": ".github/workflows/df-orchestrate.yml",
      "eventTriggers": [{ "event": "issues", "types": ["labeled"] }, { "event": "issue_comment", "types": ["created"] }, { "event": "workflow_run", "types": ["completed"] }],
      "recovery": { "cron": "*/10 * * * *", "intervalMinutes": 10, "maxDetectionMinutes": 20 },
      "settleSeconds": 30,
      "debounceSeconds": 60,
      "idempotencyKey": "worker-dispatch:{repository}:{target}:{sourceVersion}",
      "modelPolicy": "task-class-policy",
      "authorization": {
        "defaultMode": "no-op-unless-machine-ready",
        "mutationAuthority": "machine-ready-evaluation",
        "permissions": ["actions:write", "contents:write", "issues:write", "workflows:write"],
        "receiptRequired": true
      },
      "retry": { "maxAttempts": 3, "backoffSeconds": 120, "noProgressLimit": 3, "escalationLabel": "df:ask-owner" },
      "ledgerKind": "df-orchestrate"
    },
    {
      "id": "worker-heartbeat-recovery",
      "ownerIssue": 48,
      "status": "active",
      "engine": "df resume",
      "eventWorkflows": [".github/workflows/df-orchestrate.yml"],
      "recoveryWorkflow": ".github/workflows/df-orchestrate.yml",
      "eventTriggers": [{ "event": "workflow_run", "types": ["completed"] }],
      "recovery": { "cron": "*/10 * * * *", "intervalMinutes": 10, "maxDetectionMinutes": 20 },
      "settleSeconds": 60,
      "debounceSeconds": 120,
      "idempotencyKey": "worker-heartbeat-recovery:{repository}:{target}:{sourceVersion}",
      "modelPolicy": "zero-token",
      "authorization": {
        "defaultMode": "read-only",
        "mutationAuthority": "verified-interrupted-worker-receipt",
        "permissions": ["actions:write", "contents:read", "issues:write"],
        "receiptRequired": true
      },
      "retry": { "maxAttempts": 3, "backoffSeconds": 300, "noProgressLimit": 3, "escalationLabel": "df:ask-owner" },
      "ledgerKind": "df-orchestrate"
    },
    {
      "id": "worker-claim-follow-through",
      "ownerIssue": 32,
      "status": "active",
      "engine": "df verify",
      "eventWorkflows": [".github/workflows/df-verify.yml", ".github/workflows/df-follow-through.yml"],
      "recoveryWorkflow": ".github/workflows/df-follow-through.yml",
      "eventTriggers": [
        { "event": "workflow_run", "types": ["completed"] },
        { "event": "workflow_dispatch", "types": ["bot-forwarded-pull-request-closed"] }
      ],
      "recovery": { "cron": "41 */2 * * *", "intervalMinutes": 120, "maxDetectionMinutes": 140 },
      "settleSeconds": 30,
      "debounceSeconds": 60,
      "idempotencyKey": "worker-claim-follow-through:{repository}:{target}:{sourceVersion}",
      "modelPolicy": "zero-token",
      "authorization": {
        "defaultMode": "read-only",
        "mutationAuthority": "verified-worker-claim-and-green-gates",
        "permissions": ["actions:read", "checks:read", "contents:write", "issues:write", "pull-requests:write"],
        "receiptRequired": true
      },
      "retry": { "maxAttempts": 3, "backoffSeconds": 300, "noProgressLimit": 3, "escalationLabel": "df:ask-owner" },
      "ledgerKind": "df-verify"
    },
    {
      "id": "release-convergence",
      "ownerIssue": 41,
      "status": "active",
      "engine": "df release",
      "eventWorkflows": [".github/workflows/df-release.yml"],
      "recoveryWorkflow": ".github/workflows/df-release.yml",
      "eventTriggers": [{ "event": "workflow_dispatch", "types": ["bot-forwarded-pull-request-closed", "manual"] }],
      "recovery": { "cron": "11 */2 * * *", "intervalMinutes": 120, "maxDetectionMinutes": 140 },
      "settleSeconds": 60,
      "debounceSeconds": 120,
      "idempotencyKey": "release-convergence:{repository}:{target}:{sourceVersion}",
      "modelPolicy": "zero-token-unless-semantic-conflict-high",
      "authorization": {
        "defaultMode": "read-only-status",
        "mutationAuthority": "verified-green-release-plan",
        "permissions": ["actions:read", "checks:read", "contents:write", "issues:write", "pull-requests:write"],
        "receiptRequired": true
      },
      "retry": { "maxAttempts": 3, "backoffSeconds": 600, "noProgressLimit": 3, "escalationLabel": "df:ask-owner" },
      "ledgerKind": "df-release"
    },
    {
      "id": "submodule-autoupdate",
      "ownerIssue": 43,
      "status": "active",
      "engine": "df submodules update",
      "eventWorkflows": [".github/workflows/df-submodule-autoupdate.yml"],
      "recoveryWorkflow": ".github/workflows/df-submodule-autoupdate.yml",
      "eventTriggers": [{ "event": "repository_dispatch", "types": ["darkfactory-release-verified"] }],
      "recovery": { "cron": "29 */2 * * *", "intervalMinutes": 120, "maxDetectionMinutes": 140 },
      "settleSeconds": 60,
      "debounceSeconds": 180,
      "idempotencyKey": "submodule-autoupdate:{repository}:{target}:{sourceVersion}",
      "modelPolicy": "zero-token",
      "authorization": {
        "defaultMode": "read-only-status",
        "mutationAuthority": "verified-child-release-receipt",
        "permissions": ["actions:read", "checks:read", "contents:write", "pull-requests:write"],
        "receiptRequired": true
      },
      "retry": { "maxAttempts": 3, "backoffSeconds": 600, "noProgressLimit": 3, "escalationLabel": "df:ask-owner" },
      "ledgerKind": "df-submodule-update"
    },
    {
      "id": "repository-hygiene",
      "ownerIssue": 263,
      "status": "active",
      "engine": "df clean plan|apply|verify",
      "eventWorkflows": [".github/workflows/df-clean.yml"],
      "recoveryWorkflow": ".github/workflows/df-clean.yml",
      "eventTriggers": [{ "event": "schedule", "types": [] }, { "event": "workflow_dispatch", "types": [] }],
      "recovery": { "cron": "53 */4 * * *", "intervalMinutes": 240, "maxDetectionMinutes": 270 },
      "settleSeconds": 120,
      "debounceSeconds": 300,
      "idempotencyKey": "repository-hygiene:{repository}:{target}:{sourceVersion}",
      "modelPolicy": "zero-token",
      "authorization": {
        "defaultMode": "read-only-plan",
        "mutationAuthority": "admitted-clean-plan",
        "permissions": ["actions:read", "contents:write", "issues:write", "pull-requests:write"],
        "receiptRequired": true
      },
      "retry": { "maxAttempts": 2, "backoffSeconds": 900, "noProgressLimit": 2, "escalationLabel": "df:ask-owner" },
      "ledgerKind": "df-clean"
    },
    {
      "id": "provider-capacity-health",
      "ownerIssue": 46,
      "status": "planned",
      "engine": "df runners status",
      "eventWorkflows": [".github/workflows/df-health.yml"],
      "recoveryWorkflow": ".github/workflows/df-health.yml",
      "eventTriggers": [{ "event": "workflow_run", "types": ["completed"] }],
      "recovery": { "cron": "*/10 * * * *", "intervalMinutes": 10, "maxDetectionMinutes": 20 },
      "settleSeconds": 0,
      "debounceSeconds": 60,
      "idempotencyKey": "provider-capacity-health:{repository}:{target}:{sourceVersion}",
      "modelPolicy": "zero-token",
      "authorization": {
        "defaultMode": "read-only",
        "mutationAuthority": "health-receipt-only",
        "permissions": ["actions:read", "issues:write"],
        "receiptRequired": true
      },
      "retry": { "maxAttempts": 3, "backoffSeconds": 300, "noProgressLimit": 3, "escalationLabel": "df:ask-owner" },
      "ledgerKind": "df-health"
    },
    {
      "id": "dashboard-refresh",
      "ownerIssue": 54,
      "status": "active",
      "engine": "df dashboard",
      "eventWorkflows": [".github/workflows/df-orchestrate.yml"],
      "recoveryWorkflow": ".github/workflows/df-orchestrate.yml",
      "eventTriggers": [{ "event": "workflow_run", "types": ["completed"] }, { "event": "workflow_dispatch", "types": [] }],
      "recovery": { "cron": "*/10 * * * *", "intervalMinutes": 10, "maxDetectionMinutes": 20 },
      "settleSeconds": 15,
      "debounceSeconds": 60,
      "idempotencyKey": "dashboard-refresh:{repository}:{target}:{sourceVersion}",
      "modelPolicy": "zero-token",
      "authorization": {
        "defaultMode": "read-only",
        "mutationAuthority": "marker-owned-dashboard-issue",
        "permissions": ["actions:read", "issues:write"],
        "receiptRequired": true
      },
      "retry": { "maxAttempts": 3, "backoffSeconds": 300, "noProgressLimit": 3, "escalationLabel": "df:ask-owner" },
      "ledgerKind": "df-orchestrate"
    }
  ]
}
