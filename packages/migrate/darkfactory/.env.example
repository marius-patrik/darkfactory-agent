# Environment variables are for isolated deployment only. Prefer Agent OS-managed secrets locally:
# agents secrets set GITHUB_APP_ID
# agents secrets set GITHUB_PRIVATE_KEY
# agents secrets set GITHUB_WEBHOOK_SECRET
GITHUB_APP_ID=
GITHUB_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\n...\n-----END RSA PRIVATE KEY-----"
GITHUB_WEBHOOK_SECRET=
PORT=3000
LOG_LEVEL=info
# GitHub Actions managed sync secrets use these names, mapped from Agent OS secrets:
# DARK_FACTORY_APP_ID=
# DARK_FACTORY_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\n...\n-----END RSA PRIVATE KEY-----"

# Provider credentials remain in canonical Agent OS state. Managed repositories
# do not receive provider-specific review secrets.
