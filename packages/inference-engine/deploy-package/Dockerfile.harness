# Stage 1: Build & Validate the TypeScript Agent Harness
FROM oven/bun:1.2-slim AS builder

ARG AGENTS_VERSION=dev
ARG AGENTS_GIT_SHA=unknown
ARG AGENTS_IMAGE_TAG=agents/harness:dev
ARG AGENTS_BUILD_TIME=unknown

WORKDIR /app

# Copy the root monorepo package.json and lockfile
COPY package.json bun.lock ./

# Copy the agent app package.json
COPY agent/package.json ./agent/

# Install both production and devDependencies to support typechecking
RUN bun install

# Copy the actual agent harness application code
COPY agent ./agent

# Run typecheck to validate code correctness during build
WORKDIR /app/agent
RUN bun run typecheck

# Stage 2: Final runtime container
FROM ghcr.io/astral-sh/uv:latest AS uv

FROM oven/bun:1.2-slim

ARG AGENTS_VERSION=dev
ARG AGENTS_GIT_SHA=unknown
ARG AGENTS_IMAGE_TAG=agents/harness:dev
ARG AGENTS_BUILD_TIME=unknown

LABEL org.opencontainers.image.version="${AGENTS_VERSION}" \
      org.opencontainers.image.revision="${AGENTS_GIT_SHA}" \
      org.opencontainers.image.created="${AGENTS_BUILD_TIME}" \
      org.opencontainers.image.title="agents-harness"

ENV AGENTS_VERSION="${AGENTS_VERSION}" \
    AGENTS_GIT_SHA="${AGENTS_GIT_SHA}" \
    AGENTS_IMAGE_TAG="${AGENTS_IMAGE_TAG}" \
    AGENTS_BUILD_TIME="${AGENTS_BUILD_TIME}"

# git, curl, CA certs, python3, pip, venv, and uv are required by the
# dispatched-run execution contract (gateway preflight, clone branch, proof
# validation, evidence writes, commit, push) and by QFT tenant tasks that run
# pyproject/uv.lock-backed experiments.
RUN apt-get update \
  && apt-get install -y --no-install-recommends git curl ca-certificates python3 python3-pip python3-venv \
  && rm -rf /var/lib/apt/lists/*

COPY --from=uv /uv /uvx /usr/local/bin/

WORKDIR /app

# Copy the entire validated project directory
COPY --from=builder /app /app

# Execution-contract entrypoint for orchestrated runs (clone -> agent -> commit -> push).
COPY deploy/run-task.sh /app/run-task.sh
RUN chmod +x /app/run-task.sh

WORKDIR /app/agent

# Set the default entrypoint to run the agent CLI
ENTRYPOINT ["bun", "/app/agent/src/cli/agent.ts"]

