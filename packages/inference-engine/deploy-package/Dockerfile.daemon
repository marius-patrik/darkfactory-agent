# Stage 1: Build the Go binaries
FROM golang:alpine AS builder

ARG AGENTS_VERSION=dev
ARG AGENTS_GIT_SHA=unknown
ARG AGENTS_IMAGE_TAG=agents-go-services:dev
ARG AGENTS_BUILD_TIME=unknown

# Install build dependencies
RUN apk add --no-cache git ca-certificates

WORKDIR /app

# Copy dependency files first to utilize Docker layer caching
COPY go.mod go.sum ./
RUN go mod download

# Copy the Go engine source code
COPY . .

# Build both daemon and manager with CGO disabled (as modernc.org/sqlite is a pure Go SQLite driver)
RUN CGO_ENABLED=0 GOOS=linux go build -buildvcs=false -ldflags="-w -s" -o /app/bin/daemon ./cmd/daemon
RUN CGO_ENABLED=0 GOOS=linux go build -buildvcs=false -ldflags="-w -s" -o /app/bin/manager ./cmd/manager

# Stage 2: Final minimal runtime image
FROM alpine:latest

ARG AGENTS_VERSION=dev
ARG AGENTS_GIT_SHA=unknown
ARG AGENTS_IMAGE_TAG=agents-go-services:dev
ARG AGENTS_BUILD_TIME=unknown

LABEL org.opencontainers.image.version="${AGENTS_VERSION}" \
      org.opencontainers.image.revision="${AGENTS_GIT_SHA}" \
      org.opencontainers.image.created="${AGENTS_BUILD_TIME}" \
      org.opencontainers.image.title="agents-go-services"

ENV AGENTS_VERSION="${AGENTS_VERSION}" \
    AGENTS_GIT_SHA="${AGENTS_GIT_SHA}" \
    AGENTS_IMAGE_TAG="${AGENTS_IMAGE_TAG}" \
    AGENTS_BUILD_TIME="${AGENTS_BUILD_TIME}"

# Ensure ca-certificates/curl for healthchecks, kubectl for the k8s Job
# executor, and python3/openssl for QFT queue helpers and GitHub App auth.
RUN apk add --no-cache ca-certificates curl kubectl openssl python3

WORKDIR /app

# Copy pre-built binaries from stage 1
COPY --from=builder /app/bin/daemon /app/daemon
COPY --from=builder /app/bin/manager /app/manager

# Expose ports: 8080 (Daemon API), 8081 (Manager API)
EXPOSE 8080 8081

# Default entrypoint starts the scheduler daemon
ENTRYPOINT ["/app/daemon"]
