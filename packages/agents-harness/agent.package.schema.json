{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Agentos Harness Manifest",
  "description": "Schema for agent.package.json harness manifests managed by Agentos.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "id",
    "name",
    "kind",
    "description",
    "entry",
    "workingDirectory",
    "provides",
    "requires"
  ],
  "properties": {
    "schemaVersion": {
      "type": "integer",
      "minimum": 1,
      "description": "Version of the agent.package.json schema."
    },
    "id": {
      "type": "string",
      "minLength": 1,
      "description": "Stable package identifier."
    },
    "name": {
      "type": "string",
      "minLength": 1,
      "description": "Human-readable package name."
    },
    "kind": {
      "type": "string",
      "enum": ["harness"],
      "description": "Package kind. Harness packages use the value 'harness'."
    },
    "description": {
      "type": "string",
      "minLength": 1,
      "description": "Short package description."
    },
    "entry": {
      "type": "string",
      "minLength": 1,
      "description": "Default command used to run the package entrypoint."
    },
    "workingDirectory": {
      "type": "string",
      "minLength": 1,
      "description": "Working directory for the package entrypoint."
    },
    "provides": {
      "type": "array",
      "description": "Capability strings this package provides.",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "requires": {
      "type": "object",
      "additionalProperties": false,
      "description": "Runtime requirements consumed by this package.",
      "properties": {
        "clis": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "state": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    }
  }
}
