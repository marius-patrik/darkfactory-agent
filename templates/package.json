{
  "name": "@agent-os/templates",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "bun@1.3.14",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "bun run --filter '*' build",
    "ci": "bun install --frozen-lockfile && bun run clean && bun run typecheck && bun run test && bun run build",
    "clean": "rm -rf packages/*/dist",
    "dev:cli": "bun --filter @agent-os/template-cli run dev",
    "dev:web": "bun --filter @agent-os/template-web run dev",
    "start": "bun --filter @agent-os/template-web run start",
    "test": "bun run --filter '*' test",
    "typecheck": "bun run --filter '*' typecheck"
  },
  "devDependencies": {
    "bun-types": "1.3.14",
    "typescript": "5.9.3"
  }
}
