{
  "schemaVersion": 1,
  "id": "agent-darkfactory",
  "name": "darkfactory",
  "kind": "agent",
  "description": "DarkFactory GitHub App automation agent CLI.",
  "entry": "node dist/cli.js",
  "requires": {
    "state": [
      "secrets",
      "data-repos",
      "skills",
      "plugins",
      "hooks",
      "credits"
    ]
  },
  "dataRepo": {
    "id": "darkfactory-workspace",
    "repo": "marius-patrik/agentos-data",
    "path": "data/data-agentos",
    "branch": "main",
    "managedPath": "managed-repository",
    "env": "DARK_FACTORY_WORKSPACE_ROOT"
  },
  "provides": [
    "cli:darkfactory"
  ]
}

