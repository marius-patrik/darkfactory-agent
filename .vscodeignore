biome.json
jest.config.cjs
postcss.config.js
tailwind.config.js
tsconfig.json
tsconfig.test.json
bun.lock
package-lock.json
yarn.lock
pnpm-lock.yaml

# Documentation (keep README and CHANGELOG at root for marketplace)
docs/**

